{
  "name": "nextjs_tailwind_shadcn_ts",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "build:openclank-editor": "bun build src/openclank-codemirror.ts --outfile=../../static/js/copal/codemirror.js --format=esm --minify",
    "start": "python3 app.py",
    "lint": "eslint .",
    "henxels:sync": "henxels sync",
    "henxels:check": "henxels check --all",
    "henxels:manual:cant-stop-dont-stop-wont-stop": "henxels check --all --config henxels.cant-stop-dont-stop-wont-stop.yaml",
    "servo:check": "cargo check --manifest-path servo-shell/Cargo.toml",
    "servo:probe": "CARGO_TARGET_DIR=/tmp/copal-servo-target cargo check --manifest-path servo-shell/Cargo.toml --no-default-features --features servo-probe",
    "servo:runtime-check": "CARGO_TARGET_DIR=/tmp/copal-servo-target cargo check --manifest-path servo-shell/Cargo.toml --no-default-features --features servo-runtime",
    "servo:runtime-smoke": "timeout 20s env COPAL_SERVO_SMOKE=1 COPAL_URL=${COPAL_URL:-http://127.0.0.1:${PORT:-8765}} CARGO_TARGET_DIR=/tmp/copal-servo-target cargo run --manifest-path servo-shell/Cargo.toml --no-default-features --features servo-runtime",
    "servo:native-check": "CARGO_TARGET_DIR=/tmp/copal-servo-target cargo check --manifest-path servo-shell/Cargo.toml --no-default-features --features servo-runtime,native-api",
    "servo:native-smoke": "timeout 20s env COPAL_NATIVE_SMOKE=1 CARGO_TARGET_DIR=/tmp/copal-servo-target cargo run --manifest-path servo-shell/Cargo.toml --no-default-features --features servo-runtime,native-api",
    "build:native-assets": "bun run build",
    "servo:native-release": "bun run build:native-assets && CARGO_TARGET_DIR=/tmp/copal-servo-target cargo build --manifest-path servo-shell/Cargo.toml --release --no-default-features --features servo-runtime,native-api,embedded-assets",
    "servo:native-release-smoke": "bun run servo:native-release && tmp=$(mktemp -d) && cd \"$tmp\" && timeout 20s env COPAL_NATIVE_SMOKE=1 /tmp/copal-servo-target/release/copal-servo-shell",
    "native:parity": "scripts/copal-native-api-parity.sh",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "6.7.0",
    "@codemirror/view": "6.43.4",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.1.1",
    "@lezer/markdown": "^1.7.0",
    "@prisma/client": "^6.11.1",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-context-menu": "^2.2.15",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-hover-card": "^1.1.14",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.15",
    "@radix-ui/react-navigation-menu": "^1.2.13",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.14",
    "@radix-ui/react-toggle": "^1.1.9",
    "@radix-ui/react-toggle-group": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@reactuses/core": "^6.0.5",
    "@tanstack/react-query": "^5.82.0",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.23.2",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.525.0",
    "next": "^16.1.1",
    "next-auth": "^4.24.11",
    "next-intl": "^4.3.4",
    "next-themes": "^0.4.6",
    "prisma": "^6.11.1",
    "react": "^19.0.0",
    "react-day-picker": "^9.8.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.60.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^3.0.3",
    "react-syntax-highlighter": "^15.6.1",
    "recharts": "^2.15.4",
    "sharp": "^0.34.3",
    "sonner": "^2.0.6",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^11.1.0",
    "vaul": "^1.1.2",
    "z-ai-web-dev-sdk": "^0.0.18",
    "zod": "^4.0.2",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "bun-types": "^1.3.4",
    "eslint": "^9",
    "eslint-config-next": "^16.1.1",
    "henxels": "^0.8.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.3.5",
    "typescript": "^5"
  }
}
